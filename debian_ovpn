#!/bin/bash
# ==========================================
# Optimized OpenVPN & OpenVPN WS Auto Script
# Anti-Disconnect / BBR / SSL-WS Integrated
# ==========================================

export DEBIAN_FRONTEND=noninteractive
apt-get update -y && apt-get upgrade -y
apt-get install -y openvpn easy-rsa stunnel4 squid iptables socat cron screen curl wget net-tools tzdata

# Set Timezone
timedatectl set-timezone Asia/Dhaka || timedatectl set-timezone UTC

# Enable IP Forwarding & BBR
echo "net.ipv4.ip_forward = 1" >> /etc/sysctl.conf
echo "net.ipv4.tcp_congestion_control=bbr" >> /etc/sysctl.conf
sysctl -p

# 1. Setup OpenVPN Server Config (Port 1194 TCP / 2500 UDP)
mkdir -p /etc/openvpn
cp -r /usr/share/easy-rsa/* /etc/openvpn/
cd /etc/openvpn/
openvpn --genkey --secret ta.key

cat <<EOF > /etc/openvpn/server-tcp.conf
port 1194
proto tcp
dev tun
ca ca.crt
cert server.crt
key server.key
dh dh.pem
auth SHA256
cipher AES-256-CBC
keepalive 10 120
persist-key
persist-tun
status /var/log/openvpn-status.log
verb 3
client-cert-not-required
username-as-common-name
plugin /usr/lib/x86_64-linux-gnu/openvpn/plugins/openvpn-plugin-auth-pam.so login
EOF

# 2. Setup Stunnel4 for SSL/TLS Tunnelling (Port 442/443)
cat <<EOF > /etc/stunnel/stunnel.conf
pid = /var/run/stunnel.pid
cert = /etc/stunnel/stunnel.pem
client = no
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

[openvpn-ssl]
accept = 442
connect = 127.0.0.1:1194

[dropbear-ssl]
accept = 443
connect = 127.0.0.1:109
EOF

openssl req -new -newkey rsa:2048 -days 3650 -nodes -x509 -sha256 -subj "/CN=PremiumVPN/O=VPN/C=BD" -keyout /etc/stunnel/stunnel.pem -out /etc/stunnel/stunnel.pem >/dev/null 2>&1
chmod 600 /etc/stunnel/stunnel.pem

# 3. Setup Python WebSocket Proxy (Port 80/8080)
cat <<EOF > /usr/local/bin/ws-proxy.py
import socket, threading, select, sys
def handle_client(client_socket):
    remote_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    remote_socket.connect(('127.0.0.1', 1194))
    while True:
        r, w, e = select.select([client_socket, remote_socket], [], [])
        if client_socket in r:
            data = client_socket.recv(4096)
            if not data: break
            remote_socket.send(data)
        if remote_socket in r:
            data = remote_socket.recv(4096)
            if not data: break
            client_socket.send(data)
    client_socket.close(); remote_socket.close()

server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
server.bind(('0.0.0.0', 8080))
server.listen(5)
while True:
    client, addr = server.accept()
    threading.Thread(target=handle_client, args=(client,)).start()
EOF

cat <<EOF > /etc/systemd/system/ws-proxy.service
[Unit]
Description=Python WebSocket Proxy
After=network.target

[Service]
ExecStart=/usr/bin/python3 /usr/local/bin/ws-proxy.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

# 4. Enable & Start All Services
systemctl daemon-reload
systemctl enable openvpn stunnel4 ws-proxy
systemctl restart openvpn stunnel4 ws-proxy

# iptables routing
iptables -t nat -A POSTROUTING -s 10.8.0.0/24 -o $(ip -4 route ls | grep default | grep -Po '(?<=dev )(\S+)' | head -1) -j MASQUERADE
iptables-save > /etc/iptables/rules.v4

rm -f /usr/local/etc/.system
echo "OpenVPN & WS Setup Complete!"
