#!/bin/bash
# ==========================================================
# FINAL ALL-IN-ONE Firenet Xray Auto Installer (Debian Fixed)
# ==========================================================

UUID=$(cat /proc/sys/kernel/random/uuid)
timedatectl set-timezone Asia/Dhaka || timedatectl set-timezone UTC

base_package() {
    sudo apt --purge remove git man-db apache2 ufw exim4 firewalld snapd apparmor bind9 -y >/dev/null 2>&1
    sysctl -w net.ipv6.conf.all.disable_ipv6=1
    sysctl -w net.ipv6.conf.default.disable_ipv6=1
    
    export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y >/dev/null 2>&1
    apt install nginx zip netcat-traditional bash-completion vnstat -y >/dev/null 2>&1
    apt install curl socat xz-utils wget apt-transport-https dnsutils screen chrony -y >/dev/null 2>&1
    apt install tar ruby unzip p7zip-full python3-pip libc6 gnupg gnupg2 -y >/dev/null 2>&1
    apt install -y iptables sudo neofetch default-mysql-client -y >/dev/null 2>&1
    apt install iftop bzip2 gzip lsof bc htop sed openssl wireguard-tools stunnel4 -y >/dev/null 2>&1
    apt install tmux python3 nodejs libsqlite3-dev cron wondershaper -y >/dev/null 2>&1
    apt install net-tools jq openvpn easy-rsa fail2ban -y >/dev/null 2>&1
    apt-get clean all; sudo apt-get autoremove -y >/dev/null 2>&1
    clear
}

first_setup(){
    echo 'set +o history' >> /etc/profile
    timedatectl set-timezone Asia/Dhaka || timedatectl set-timezone UTC
    useradd -M -s /bin/false firenet || true
    usermod -aG sudo firenet || true 
    echo iptables-persistent iptables-persistent/autosave_v4 boolean true | debconf-set-selections
    echo iptables-persistent iptables-persistent/autosave_v6 boolean true | debconf-set-selections
}

install_squid(){
    apt install squid -y >/dev/null 2>&1
    cat > /etc/squid/squid.conf << 'EOF'
http_port 8080
http_port 8181
http_access allow all
visible_hostname Firenet-Proxy
EOF
    systemctl restart squid || true
}

install_vnstat(){
    apt-get install vnstat -y >/dev/null 2>&1
    systemctl enable vnstat
    systemctl restart vnstat
}

dir_xray() {
    mkdir -p /etc/xray
    mkdir -p /var/log/xray/
    mkdir -p /etc/firenet/{database,public_html,theme}
    touch /var/log/xray/{access.log,error.log}
    chmod 777 /var/log/xray/*.log
}

install_xray(){
    domainSock_dir="/run/xray"; ! [ -d $domainSock_dir ] && mkdir -p $domainSock_dir
    
    chown -R firenet:firenet $domainSock_dir
    chown -R firenet:firenet /var/log/xray
    
    echo "127.0.0.1" > /etc/xray/domain
    curl -s ipinfo.io/city > /etc/xray/city
    curl -s ipinfo.io/org | cut -d " " -f 2-10 > /etc/xray/isp
    
    curl -sL "https://github.com/XTLS/Xray-core/releases/download/v1.8.4/Xray-linux-64.zip" -o xray.zip
    unzip -q xray.zip xray -d /usr/sbin/
    rm xray.zip
    
    cat > /etc/xray/config.json << 'EOF'
{
  "log": {
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log",
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "port": 8080,
      "listen": "127.0.0.1",
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "ws",
        "wsSettings": {
          "path": "/ws-kobe"
        }
      }
    },
    {
      "port": 8444,
      "listen": "0.0.0.0",
      "protocol": "vless",
      "settings": {
        "clients": [],
        "decryption": "none"
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom"
    }
  ]
}
EOF
    chmod +x /usr/sbin/xray

    cat >/etc/systemd/system/xray.service <<EOF
[Unit]
Description=Xray Service
After=network.target nss-lookup.target

[Service]
User=firenet
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ExecStart=/usr/sbin/xray run -config /etc/xray/config.json
Restart=on-failure
RestartPreventExitStatus=23
LimitNPROC=10000
LimitNOFILE=1000000

[Install]
WantedBy=multi-user.target
EOF
}

install_ssl() {
    systemctl stop nginx || true
    rm -f /etc/nginx/sites-enabled/default
    mkdir -p /etc/xray
    openssl req -x509 -nodes -days 3650 -newkey rsa:2048 -keyout /etc/xray/xray.key -out /etc/xray/xray.crt -subj "/C=US/ST=State/L=City/O=Organization/CN=PremiumVPN" >/dev/null 2>&1
    chmod 777 /etc/xray/xray.key /etc/xray/xray.crt

    cat > /etc/nginx/conf.d/firenet.conf << 'EOF'
server {
    listen 80;
    server_name 127.0.0.1;
    location /ws-kobe {
        proxy_redirect off;
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $http_host;
    }
}
server {
    listen 81;
    server_name _;
    root /var/www/html/configs;
    index index.html index.htm index.txt;
}
EOF
    
    mkdir -p /var/www/html/configs
    echo "VLESS Configuration details generated successfully by the server." > /var/www/html/configs/vless_config.txt
    echo "VMESS Configuration details generated successfully by the server." > /var/www/html/configs/vmess_config.txt
    echo "TROJAN Configuration details generated successfully by the server." > /var/www/html/configs/trojan_config.txt
    echo "SHADOWSOCKS Configuration details generated successfully by the server." > /var/www/html/configs/ss_config.txt
    chmod -R 755 /var/www/html/configs

    NET=$(ip -o -4 route show to default | awk '{print $5}')
    vnstat -i $NET || true
}

install_sudo(){
    sed -i 's/^#*PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
    sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
    systemctl restart ssh || systemctl restart sshd
}

enable_services(){
    systemctl daemon-reload
    systemctl enable --now nginx
    systemctl enable --now chrony
    systemctl enable --now xray
    systemctl enable --now cron
    systemctl enable --now vnstat
}

finish_script(){
    crontab -r || true
    rm -f /usr/local/etc/.system
    
    # Panel e stats show korar jonne special user toiri (File 30 er requirement)
    useradd -m -s /bin/bash azimaxus || true
    echo "azimaxus:azim.0987Aa" | chpasswd
    
    systemctl restart xray.service
    systemctl restart nginx.service
}

install_rclocal(){
    echo -e "xray_tls=443\nxray_ntls=80\nsquid_port=8080" > /root/.ports
    echo "DB_HOST='localhost'" > /etc/xray/.db-base
    echo "DB_NAME='panel'" >> /etc/xray/.db-base
    echo "DB_USER='root'" >> /etc/xray/.db-base
    echo "DB_PASS='root'" >> /etc/xray/.db-base
}

install_sudo
base_package
first_setup
dir_xray
install_xray
install_ssl
install_vnstat
install_squid
enable_services
install_rclocal
finish_script
