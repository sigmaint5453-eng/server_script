#!/bin/bash
# ==========================================
# Optimized SSH WS & BadVPN UDPGW Script
# Low Ping for Gaming / Fast Voice Calls
# ==========================================

export DEBIAN_FRONTEND=noninteractive
apt-get update -y
apt-get install -y dropbear openssh-server stunnel4 cmake make gcc build-essential screen cron wget curl

# 1. Setup Dropbear (Port 109, 143)
sed -i 's/NO_START=1/NO_START=0/g' /etc/default/dropbear
sed -i 's/DROPBEAR_PORT=22/DROPBEAR_PORT=109/g' /etc/default/dropbear
sed -i 's/DROPBEAR_EXTRA_ARGS=/DROPBEAR_EXTRA_ARGS="-p 143"/g' /etc/default/dropbear
echo "/bin/false" >> /etc/shells

# 2. Setup BadVPN UDPGW for Gaming (Port 7300 & 7100)
cd /tmp
wget -q https://github.com/ambrop72/badvpn/archive/master.zip
unzip -q master.zip
cd badvpn-master
mkdir -p build && cd build
cmake .. -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1 >/dev/null 2>&1
make install >/dev/null 2>&1

cat <<EOF > /etc/systemd/system/badvpn1.service
[Unit]
Description=BadVPN UDPGW Gaming Service
After=network.target

[Service]
ExecStart=/usr/local/bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 --max-clients 1000 --max-connections-for-client 10
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

# 3. Setup SSH WebSocket Proxy on Port 80
cat <<EOF > /usr/local/bin/ssh-ws.py
import socket, threading, select
def handle(cs):
    rs = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    rs.connect(('127.0.0.1', 109))
    while True:
        r, w, e = select.select([cs, rs], [], [])
        if cs in r:
            d = cs.recv(4096)
            if not d: break
            rs.send(d)
        if rs in r:
            d = rs.recv(4096)
            if not d: break
            cs.send(d)
    cs.close(); rs.close()

s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
s.bind(('0.0.0.0', 80))
s.listen(5)
while True:
    c, a = s.accept()
    threading.Thread(target=handle, args=(c,)).start()
EOF

cat <<EOF > /etc/systemd/system/ssh-ws.service
[Unit]
Description=SSH WebSocket Proxy
After=network.target

[Service]
ExecStart=/usr/bin/python3 /usr/local/bin/ssh-ws.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF

# 4. Enable & Restart All Services
systemctl daemon-reload
systemctl enable dropbear badvpn1 ssh-ws
systemctl restart dropbear badvpn1 ssh-ws

# Auto Clear RAM Cache at 4 AM daily
(crontab -l 2>/dev/null; echo "0 4 * * * sync; echo 3 > /proc/sys/vm/drop_caches") | crontab -

rm -f /usr/local/etc/.system
echo "SSH WS & Gaming Setup Complete!"
